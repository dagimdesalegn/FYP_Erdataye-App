# ── Supabase ──────────────────────────────────────────────────────────────────
# Your project URL (Dashboard → Settings → API)
SUPABASE_URL=https://your-project-ref.supabase.co

# Service-role key — KEEP THIS SECRET (never put in the mobile app)
# Dashboard → Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# JWT Secret — Dashboard → Settings → API → JWT Settings → JWT Secret
SUPABASE_JWT_SECRET=your_jwt_secret_here

# ── DeepSeek ──────────────────────────────────────────────────────────────────
# Get yours at https://platform.deepseek.com
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated allowed origins. Use * for local dev only.
ALLOWED_ORIGINS=http://localhost:8081,http://localhost:19006,exp://localhost:8081
