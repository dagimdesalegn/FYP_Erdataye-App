# Expo / client bundle (only EXPO_PUBLIC_ variables are exposed to the app bundle)
EXPO_PUBLIC_SUPABASE_URL=https://your-supabase-project.supabase.co
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-supabase-anon-key
EXPO_PUBLIC_BACKEND_URL=http://10.0.2.2:8000

# Backend-only secrets (never start with EXPO_PUBLIC_)
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key
SUPABASE_JWT_SECRET=replace-with-supabase-jwt-secret
DEEPSEEK_API_KEY=replace-with-deepseek-key
ALLOWED_ORIGINS=http://localhost:19006,http://10.0.2.2:8000
